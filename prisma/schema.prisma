generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  trips       Trip[]
  tripMembers TripMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// TripStatus values: PLANNING | CONFIRMED | IN_PROGRESS | COMPLETED | CANCELLED
model Trip {
  id          String   @id @default(cuid())
  title       String
  destination String
  description String?
  status      String   @default("PLANNING")
  startDate   DateTime?
  endDate     DateTime?
  coverImage  String?
  currency    String   @default("BRL")
  budget      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  owner          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  members        TripMember[]
  activities     Activity[]
  accommodations Accommodation[]
  transports     Transport[]
  expenses       Expense[]
  documents      Document[]
  packingList    PackingList?
}

// MemberRole values: OWNER | EDITOR | VIEWER
model TripMember {
  id     String @id @default(cuid())
  tripId String
  userId String
  role   String @default("VIEWER")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
}

// ActivityType values: ACTIVITY | MEAL | TRANSPORT | ACCOMMODATION | EVENT | OTHER
model Activity {
  id          String   @id @default(cuid())
  tripId      String
  title       String
  description String?
  type        String   @default("ACTIVITY")
  date        DateTime
  startTime   String?
  endTime     String?
  location    String?
  address     String?
  bookingRef  String?
  cost        Float?
  notes       String?
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// AccommodationType values: HOTEL | HOSTEL | AIRBNB | RESORT | POUSADA | OTHER
model Accommodation {
  id                 String   @id @default(cuid())
  tripId             String
  name               String
  type               String   @default("HOTEL")
  address            String?
  checkIn            DateTime
  checkOut           DateTime
  confirmationNumber String?
  phone              String?
  website            String?
  cost               Float?
  notes              String?
  createdAt          DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// TransportType values: FLIGHT | BUS | TRAIN | CAR | BOAT | OTHER
model Transport {
  id            String   @id @default(cuid())
  tripId        String
  type          String   @default("FLIGHT")
  from          String
  to            String
  departureTime DateTime
  arrivalTime   DateTime?
  carrier       String?
  bookingRef    String?
  seat          String?
  cost          Float?
  notes         String?
  createdAt     DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// ExpenseCategory values: ACCOMMODATION | TRANSPORT | FOOD | ACTIVITY | SHOPPING | HEALTH | OTHER
model Expense {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  category  String   @default("OTHER")
  amount    Float
  currency  String   @default("BRL")
  date      DateTime
  notes     String?
  paidBy    String?
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// DocumentType values: PASSPORT | VISA | INSURANCE | TICKET | VOUCHER | OTHER
model Document {
  id        String    @id @default(cuid())
  tripId    String
  title     String
  type      String    @default("OTHER")
  url       String?
  expiresAt DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model PackingList {
  id        String      @id @default(cuid())
  tripId    String      @unique
  createdAt DateTime    @default(now())
  items     PackingItem[]

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model PackingItem {
  id            String   @id @default(cuid())
  packingListId String
  name          String
  category      String?
  isPacked      Boolean  @default(false)
  quantity      Int      @default(1)
  createdAt     DateTime @default(now())

  packingList PackingList @relation(fields: [packingListId], references: [id], onDelete: Cascade)
}
