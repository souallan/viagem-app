generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  // Preferences
  country       String?
  currency      String?   @default("BRL")
  bio           String?
  // Referral
  referralCode  String?   @unique
  referredBy    String?
  // Moderation
  bannedAt      DateTime?
  banReason     String?
  // Role values: USER | ADMIN
  role                 String    @default("USER")
  // Plan values: FREE | PREMIUM
  plan                 String    @default("FREE")
  planExpiresAt        DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  trips            Trip[]
  tripMembers      TripMember[]
  experiences      Experience[]
  communityRoutes  CommunityRoute[]
  routeComments    RouteComment[]
  posts            Post[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// TripStatus values: PLANNING | CONFIRMED | IN_PROGRESS | COMPLETED | CANCELLED
model Trip {
  id          String   @id @default(cuid())
  title       String
  destination String
  description String?
  status      String   @default("PLANNING")
  startDate   DateTime?
  endDate     DateTime?
  coverImage  String?
  currency    String   @default("BRL")
  budget      Float?
  alertsEnabled Boolean @default(false)
  shareToken  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  owner          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  members        TripMember[]
  participants   TripParticipant[]
  activities     Activity[]
  accommodations Accommodation[]
  transports     Transport[]
  expenses       Expense[]
  documents      Document[]
  packingList    PackingList?
  prepItems      TripPrepItem[]
  journalEntries JournalEntry[]
}

// MemberRole values: OWNER | EDITOR | VIEWER
model TripMember {
  id     String @id @default(cuid())
  tripId String
  userId String
  role   String @default("VIEWER")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
}

// ActivityType values: ACTIVITY | MEAL | TRANSPORT | ACCOMMODATION | EVENT | OTHER
model Activity {
  id          String   @id @default(cuid())
  tripId      String
  title       String
  description String?
  type        String   @default("ACTIVITY")
  date        DateTime
  startTime   String?
  endTime     String?
  city        String?
  location    String?
  address     String?
  bookingRef  String?
  cost        Float?
  notes       String?
  attachmentUrl String?
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// AccommodationType values: HOTEL | HOSTEL | AIRBNB | RESORT | POUSADA | OTHER
model Accommodation {
  id                 String   @id @default(cuid())
  tripId             String
  name               String
  type               String   @default("HOTEL")
  address            String?
  checkIn            DateTime
  checkOut           DateTime
  confirmationNumber String?
  phone              String?
  website            String?
  cost               Float?
  currency           String   @default("BRL")
  notes              String?
  attachmentUrl      String?
  createdAt          DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// TransportType values: FLIGHT | BUS | TRAIN | CAR | BOAT | OTHER
model Transport {
  id            String   @id @default(cuid())
  tripId        String
  type          String   @default("FLIGHT")
  from          String
  to            String
  departureTime DateTime
  arrivalTime   DateTime?
  carrier       String?
  bookingRef    String?
  seat          String?
  cost          Float?
  notes         String?
  createdAt     DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// ExpenseCategory values: ACCOMMODATION | TRANSPORT | FOOD | ACTIVITY | SHOPPING | HEALTH | OTHER
model Expense {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  category  String   @default("OTHER")
  amount    Float
  currency  String   @default("BRL")
  date      DateTime
  notes     String?
  paidBy    String?
  paidById  String?
  createdAt DateTime @default(now())

  trip   Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  shares ExpenseShare[]
}

// Participante da viagem (pessoa que divide as contas). userId opcional vincula a uma conta.
model TripParticipant {
  id        String   @id @default(cuid())
  tripId    String
  name      String
  userId    String?
  createdAt DateTime @default(now())

  trip   Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  shares ExpenseShare[]

  @@index([tripId])
}

// Divisão de uma despesa entre participantes (quem racha aquela conta).
model ExpenseShare {
  id            String @id @default(cuid())
  expenseId     String
  participantId String

  expense     Expense         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participant TripParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([expenseId, participantId])
  @@index([participantId])
}

// DocumentType values: PASSPORT | VISA | INSURANCE | TICKET | VOUCHER | OTHER
model Document {
  id        String    @id @default(cuid())
  tripId    String
  title     String
  type      String    @default("OTHER")
  url       String?
  expiresAt DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model PackingList {
  id        String      @id @default(cuid())
  tripId    String      @unique
  createdAt DateTime    @default(now())
  items     PackingItem[]

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model PackingItem {
  id            String   @id @default(cuid())
  packingListId String
  name          String
  category      String?
  isPacked      Boolean  @default(false)
  quantity      Int      @default(1)
  createdAt     DateTime @default(now())

  packingList PackingList @relation(fields: [packingListId], references: [id], onDelete: Cascade)
}

// Category values: DOCUMENTOS | SAUDE | FINANCEIRO | BAGAGEM | HOSPEDAGEM | TRANSPORTE | OUTRO
model TripPrepItem {
  id          String   @id @default(cuid())
  tripId      String
  title       String
  category    String   @default("OUTRO")
  isDone      Boolean  @default(false)
  dueDate     DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id        String   @id @default(cuid())
  tripId    String
  date      DateTime
  title     String?
  content   String
  mood      String?
  photos    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model CommunityRoute {
  id              String              @id @default(cuid())
  userId          String
  authorName      String              @default("Viajante")
  title           String
  destination     String
  country         String              @default("")
  continent       String              @default("Outros")
  flag            String              @default("📍")
  duration        Int
  coverImage      String?
  description     String
  tags            String              @default("")
  highlights      String              @default("[]")
  currency        String              @default("BRL")
  estimatedBudget String              @default("")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities CommunityActivity[]
  comments   RouteComment[]
}

model RouteComment {
  id        String   @id @default(cuid())
  routeId   String
  userId    String
  userName  String   @default("Viajante")
  content   String
  createdAt DateTime @default(now())

  route CommunityRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommunityActivity {
  id          String         @id @default(cuid())
  routeId     String
  title       String
  type        String         @default("ACTIVITY")
  day         Int
  startTime   String?
  endTime     String?
  location    String?
  description String?
  cost        Float?

  route CommunityRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
}

// AuditAction values: USER_DELETE | USER_ROLE_CHANGE | CONTENT_DELETE | DATA_EXPORT | ACCOUNT_DELETE | CONSENT_ACCEPT
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String
  targetId   String?
  targetType String?
  detail     String?
  ip         String?
  createdAt  DateTime @default(now())
}

model NewsletterSubscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  confirmedAt DateTime?
  createdAt  DateTime @default(now())
}

// ── Admin-managed content ────────────────────────────────────────────────────

// Admin posts / publicações: artigos, guias, novidades (com suporte a vídeo embed)
model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  coverImage  String?
  destination String?
  videoUrl    String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  tags        String   @default("")
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// Banners / anúncios do site (máximo 1 ativo por vez)
model SiteAnnouncement {
  id        String  @id @default(cuid())
  text      String
  linkLabel String?
  linkUrl   String?
  type      String  @default("info")
  active    Boolean @default(false)
  createdAt DateTime @default(now())
}

// Mood values: AMAZING | GREAT | GOOD | MIXED | CHALLENGING
model Experience {
  id             String   @id @default(cuid())
  userId         String
  title          String
  destination    String
  tripDate       String
  coverImage     String?
  excerpt        String?
  content        String
  rating         Int?
  mood           String?
  tags           String?
  publishedAsTip Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
